/* ============================================================================
   Firestore Security Rules — Hornhausen-Hof
   ============================================================================
   WICHTIG: Diese Datei hier ist nur eine ARCHIV-/VERSIONS-KOPIE. Sie wird
   NICHT automatisch von Firebase gelesen! Damit sie wirklich gilt, musst du
   sie manuell in der Firebase-Konsole einfügen:

     Firebase-Konsole -> dein Projekt -> Firestore Database -> Reiter
     "Regeln" -> kompletten bisherigen Inhalt löschen -> den Inhalt dieser
     Datei hier hineinkopieren -> "Veröffentlichen" klicken.

   Diese Datei ist die 1:1 übernommene, bisherige Fassung (users/usernames/
   adminLog/presence/kontakte bleiben unverändert, inkl. "unantastbar"-
   Schutz, Selbstheilungs-Mechanismus für befristete Sperren, ...) - ergänzt
   um die neuen Collections der Hofverwaltung (produkte, bestellungen,
   angebote, verkaeufe, kataloge) und bereinigt um die medizinspezifischen
   Collections, die es in der neuen App nicht mehr gibt (department,
   notizen, verkaufslog, ankuendigungen, handbuch + darfHandbuchSehen()).
   Falls dort noch alte Daten liegen, bleiben sie einfach ungenutzt in der
   Datenbank liegen - das schadet nichts, sie sind über die neue Seite nur
   nicht mehr erreichbar.
   ============================================================================ */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /* ------------------------------------------------------------------
       Hilfsfunktionen
       ------------------------------------------------------------------ */

    // Ist überhaupt jemand eingeloggt (egal welcher Status)?
    function istEingeloggt() {
      return request.auth != null;
    }

    // Lädt das eigene users/{uid}-Dokument des gerade eingeloggten Kontos.
    // Wichtig: get() zählt NICHT als "list" - das ist erlaubt, auch wenn
    // man selbst (noch) gar keine Leserechte auf die users-Collection als
    // Ganzes hat.
    function eigenesUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Ist der eingeloggte Nutzer ein Admin (= Verwalter)? Unabhängig vom
    // Rang (Hofherr/Hofmeister/Stallmeister/Hofarbeiter/Knecht/Tagelöhner).
    function istAdmin() {
      return istEingeloggt() && eigenesUserDoc().isAdmin == true;
    }

    // Prüft, ob die EIGENE zeitlich befristete Sperre (falls vorhanden)
    // bereits abgelaufen ist. "gesperrtBis" ist ein Timestamp-Feld, das nur
    // bei einer befristeten (nicht dauerhaften) Sperre gesetzt wird.
    // request.time ist die von Firebase selbst ermittelte, vertrauenswürdige
    // Serverzeit - kann vom Client nicht gefälscht werden.
    function eigeneSperreAbgelaufen() {
      let eigene = eigenesUserDoc();
      return eigene.status == 'locked'
        && eigene.get('gesperrtBis', null) != null
        && request.time > eigene.gesperrtBis;
    }

    // Ist der eingeloggte Nutzer freigegeben? Zählt sowohl "approved" als
    // auch eine befristete Sperre, deren Zeit bereits abgelaufen ist - so
    // funktioniert die zeitliche Sperre auch OHNE eigenen Server/Cloud
    // Function, rein anhand der von Firebase selbst geprüften Uhrzeit.
    function istFreigegeben() {
      return istEingeloggt() && (eigenesUserDoc().status == 'approved' || eigeneSperreAbgelaufen());
    }

    // Ist DAS BETROFFENE Dokument (nicht der eingeloggte Nutzer, sondern
    // das Dokument, das gerade geändert werden soll) als "unantastbar"
    // markiert? Über resource.data.get(...) mit Standardwert false, damit
    // das für alle "normalen" Accounts ohne dieses Feld nicht crasht.
    function istUnantastbar() {
      return resource.data.get('geschuetzt', false) == true;
    }

    // Verhindert genau zwei Dinge bei einem "unantastbar" markierten
    // Account: dass ihm die Admin-/Verwalterrechte entzogen werden, oder
    // dass sein Status von "approved" weggeändert wird (z. B. Sperren/
    // Ablehnen). Alles andere (Rang ändern, Notiz setzen, Umbenennen)
    // bleibt für Verwalter ganz normal weiter möglich.
    function verletztUnantastbarkeit() {
      let geaenderteFelder = request.resource.data.diff(resource.data).affectedKeys();
      return istUnantastbar() &&
        (
          (geaenderteFelder.hasAny(['isAdmin']) && request.resource.data.isAdmin == false) ||
          (geaenderteFelder.hasAny(['status']) && request.resource.data.status != 'approved')
        );
    }

    /* ------------------------------------------------------------------
       users/{uid} — ein Dokument pro Account, Dokument-ID = Firebase-Auth-UID
       ------------------------------------------------------------------ */
    match /users/{uid} {
      // Einzelnes Dokument lesen: das eigene, oder wenn man Verwalter ist
      allow get: if istEingeloggt() && (request.auth.uid == uid || istAdmin());

      // Die GESAMTE Liste lesen (für die Benutzerverwaltung): nur Verwalter
      allow list: if istAdmin();

      // Neuen Account anlegen: nur das eigene Dokument, und zwingend mit
      // status "pending" und isAdmin false - so kann sich niemand selbst
      // sofort freischalten oder zum Verwalter machen, egal was das
      // Frontend schickt.
      allow create: if istEingeloggt()
                    && request.auth.uid == uid
                    && request.resource.data.status == 'pending'
                    && request.resource.data.isAdmin == false;

      // Ändern: Verwalter dürfen alles ändern (Freigeben/Ablehnen/Sperren/
      // Rang/Verwalterrechte/Notiz/Umbenennen) - AUSSER bei einem als
      // "geschuetzt: true" markierten Account darf selbst ein Verwalter
      // nicht die Verwalterrechte entziehen oder den Freigabe-Status
      // wegändern (siehe verletztUnantastbarkeit() oben). Der Account
      // selbst darf NUR sein eigenes "lastLogin"-Feld aktualisieren (beim
      // Einloggen) - ODER, als dritte Ausnahme, sich selbst von "locked"
      // zurück auf "approved" setzen, aber NUR wenn die eigene befristete
      // Sperre laut Server-Uhrzeit bereits abgelaufen ist (siehe
      // eigeneSperreAbgelaufen oben). Das ist der "Selbstheilungs"-
      // Mechanismus, der eine zeitlich befristete Sperre automatisch enden
      // lässt, ganz ohne eigenen Server/Cloud Function.
      allow update: if (istAdmin() && !verletztUnantastbarkeit())
                    || (request.auth.uid == uid
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastLogin']))
                    || (request.auth.uid == uid
                        && resource.data.status == 'locked'
                        && resource.data.get('gesperrtBis', null) != null
                        && request.time > resource.data.gesperrtBis
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'lastLogin', 'gesperrtBis'])
                        && request.resource.data.status == 'approved');

      // Löschen: nur Verwalter, und niemals bei einem "geschuetzt"-Account.
      allow delete: if istAdmin() && !istUnantastbar();
    }

    /* ------------------------------------------------------------------
       usernames/{nameKleingeschrieben} — reserviert einen Benutzernamen,
       damit er nicht doppelt vergeben werden kann. Dokument enthält nur
       { uid }. Getrennt von "users", weil eine Verfügbarkeits-Prüfung per
       get() funktionieren muss, auch BEVOR man Verwalter oder überhaupt
       freigegeben ist (z. B. während der Registrierung selbst).
       ------------------------------------------------------------------ */
    match /usernames/{name} {
      // Jeder (auch nicht eingeloggt) darf prüfen, ob ein Name frei ist -
      // das Dokument enthält keine sensiblen Daten, nur eine UID.
      allow get: if true;

      // Niemand darf die komplette Namensliste auf einmal abfragen.
      allow list: if false;

      // Einen Namen reservieren: nur für die eigene UID (bei Registrierung)
      // oder durch einen Verwalter (z. B. beim direkten Anlegen eines
      // Kontos oder beim Umbenennen).
      allow create: if istEingeloggt() && (request.resource.data.uid == request.auth.uid || istAdmin());

      // Ein reserviertes Dokument wird nie "geändert", nur neu angelegt
      // oder gelöscht (siehe benenneUm in js/auth.js) - daher grundsätzlich
      // gesperrt.
      allow update: if false;

      // Freigeben (z. B. beim Umbenennen der alte Name, oder beim Löschen
      // eines Accounts): nur Verwalter.
      allow delete: if istAdmin();
    }

    /* ------------------------------------------------------------------
       adminLog/{logId} — Aktivitäts-Log für die Verwaltung. Ein Eintrag
       pro Verwalter-Aktion (Freigeben, Sperren, Rang ändern, Löschen, ...),
       geschrieben von js/auth.js. Absichtlich unveränderlich: einmal
       geschrieben, kann ein Eintrag NIE mehr geändert oder gelöscht werden
       (auch nicht von einem Verwalter) - sonst wäre das Log selbst nicht
       mehr vertrauenswürdig.
       ------------------------------------------------------------------ */
    match /adminLog/{logId} {
      allow create: if istAdmin();
      allow list, get: if istAdmin();
      allow update, delete: if false;
    }

    /* ------------------------------------------------------------------
       presence/{dokument} — Online-Anzeige (Heartbeat je Browser-Tab).
       ------------------------------------------------------------------ */
    match /presence/{dokument} {
      allow read, write: if istFreigegeben();
    }

    /* ------------------------------------------------------------------
       kontakte/{dokument} — Telegramm-Verzeichnis (BW-...), unverändert
       aus dem bisherigen Projekt übernommen.
       ------------------------------------------------------------------ */
    match /kontakte/{dokument} {
      allow read, write: if istFreigegeben();
    }

    /* ------------------------------------------------------------------
       Neue Collections der Hofverwaltung
       ------------------------------------------------------------------ */

    // Waren & Preise: alle freigegebenen Nutzer dürfen die Preisliste
    // sehen (auch für den Handelsrechner nötig), aber nur Verwalter dürfen
    // Produkte anlegen/bearbeiten/löschen oder den Lagerbestand ändern.
    match /produkte/{dokument} {
      allow read: if istFreigegeben();
      allow write: if istAdmin();
    }

    // Bestellungen: jeder freigegebene Nutzer darf Bestellungen anlegen,
    // bearbeiten (z. B. Status ändern) und löschen.
    match /bestellungen/{dokument} {
      allow read, write: if istFreigegeben();
    }

    // Handelsrechner-Angebote (Ledger "Letzte Angebote").
    match /angebote/{dokument} {
      allow read, write: if istFreigegeben();
    }

    // Verkaufslog: Eintragen/Ändern für alle freigegebenen Nutzer, Löschen
    // (inkl. Rückbuchung ins Lager) nur für Verwalter.
    match /verkaeufe/{dokument} {
      allow read, create, update: if istFreigegeben();
      allow delete: if istAdmin();
    }

    // Verwaltete Kataloge (z. B. die Rollen-Liste der Kontakte-Seite):
    // lesen dürfen alle freigegebenen Nutzer, ändern nur Verwalter.
    match /kataloge/{dokument} {
      allow read: if istFreigegeben();
      allow write: if istAdmin();
    }
  }
}
