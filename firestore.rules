/* ============================================================================
   Firestore Security Rules — Black Wolf Medical
   ============================================================================
   WICHTIG: Diese Datei hier im Repo ist nur eine ARCHIV-/VERSIONS-KOPIE.
   Sie wird NICHT automatisch von Firebase gelesen! Damit sie wirklich
   gilt, musst du sie manuell in der Firebase-Konsole einfügen:

     Firebase-Konsole -> dein Projekt -> Firestore Database -> Reiter
     "Regeln" -> kompletten bisherigen Inhalt löschen -> den Inhalt dieser
     Datei hier hineinkopieren -> "Veröffentlichen" klicken.

   Diese Regeln sorgen dafür, dass die Rechteprüfung nicht nur im Frontend
   (also im JavaScript-Code, den man theoretisch manipulieren könnte)
   passiert, sondern direkt von Firebase selbst durchgesetzt wird — ein
   nicht freigegebener oder gesperrter Account kommt also NIEMALS an Daten,
   egal was im Browser passiert.
   ============================================================================ */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /* ------------------------------------------------------------------
       Hilfsfunktionen
       ------------------------------------------------------------------ */

    // Ist überhaupt jemand eingeloggt (egal welcher Status)?
    function istEingeloggt() {
      return request.auth != null;
    }

    // Lädt das eigene users/{uid}-Dokument des gerade eingeloggten Kontos.
    // Wichtig: get() zählt NICHT als "list" - das ist erlaubt, auch wenn
    // man selbst (noch) gar keine Leserechte auf die users-Collection als
    // Ganzes hat.
    function eigenesUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Ist der eingeloggte Nutzer ein Admin? (unabhängig vom Rang)
    function istAdmin() {
      return istEingeloggt() && eigenesUserDoc().isAdmin == true;
    }

    // Darf der eingeloggte Nutzer das Handbuch (interne Dokumentenbibliothek)
    // überhaupt SEHEN? Ausschließlich anhand des Rangs geprüft (rolle) -
    // unabhängig von isAdmin, das stattdessen nur die BEARBEITUNG einzelner
    // Dokumente steuert (siehe /handbuch/{dokument} weiter unten). Muss hier
    // serverseitig geprüft werden, nicht nur im Frontend (js/app.js blendet
    // den Reiter zwar aus, das allein wäre aber kein echter Schutz).
    function darfHandbuchSehen() {
      return istEingeloggt() && eigenesUserDoc().rolle in [
        'Stellv. Oberarzt', 'Oberarzt', 'Stellv. Chefarzt', 'Chefarzt', 'Ärztliche Direktion'
      ];
    }

    // Prüft, ob die EIGENE zeitlich befristete Sperre (falls vorhanden)
    // bereits abgelaufen ist. "gesperrtBis" ist ein Timestamp-Feld, das nur
    // bei einer befristeten (nicht dauerhaften) Sperre gesetzt wird.
    // request.time ist die von Firebase selbst ermittelte, vertrauenswürdige
    // Serverzeit - kann vom Client nicht gefälscht werden.
    function eigeneSperreAbgelaufen() {
      let eigene = eigenesUserDoc();
      return eigene.status == 'locked'
        && eigene.get('gesperrtBis', null) != null
        && request.time > eigene.gesperrtBis;
    }

    // Ist der eingeloggte Nutzer freigegeben? Zählt sowohl "approved" als
    // auch eine befristete Sperre, deren Zeit bereits abgelaufen ist - so
    // funktioniert die zeitliche Sperre auch OHNE eigenen Server/Cloud
    // Function, rein anhand der von Firebase selbst geprüften Uhrzeit.
    function istFreigegeben() {
      return istEingeloggt() && (eigenesUserDoc().status == 'approved' || eigeneSperreAbgelaufen());
    }

    // Ist DAS BETROFFENE Dokument (nicht der eingeloggte Nutzer, sondern
    // das Dokument, das gerade geändert werden soll) als "unantastbar"
    // markiert? Über resource.data.get(...) mit Standardwert false, damit
    // das für alle "normalen" Accounts ohne dieses Feld nicht crasht.
    function istUnantastbar() {
      return resource.data.get('geschuetzt', false) == true;
    }

    // Verhindert genau zwei Dinge bei einem "unantastbar" markierten
    // Account: dass ihm die Admin-Rechte entzogen werden, oder dass sein
    // Status von "approved" weggeändert wird (z. B. Sperren/Ablehnen).
    // Alles andere (Rolle ändern, Notiz setzen, Umbenennen) bleibt für
    // Admins ganz normal weiter möglich.
    function verletztUnantastbarkeit() {
      let geaenderteFelder = request.resource.data.diff(resource.data).affectedKeys();
      return istUnantastbar() &&
        (
          (geaenderteFelder.hasAny(['isAdmin']) && request.resource.data.isAdmin == false) ||
          (geaenderteFelder.hasAny(['status']) && request.resource.data.status != 'approved')
        );
    }

    /* ------------------------------------------------------------------
       users/{uid} — ein Dokument pro Account, Dokument-ID = Firebase-Auth-UID
       ------------------------------------------------------------------ */
    match /users/{uid} {
      // Einzelnes Dokument lesen: das eigene, oder wenn man Admin ist
      allow get: if istEingeloggt() && (request.auth.uid == uid || istAdmin());

      // Die GESAMTE Liste lesen (für die Benutzerverwaltung): nur Admins
      allow list: if istAdmin();

      // Neuen Account anlegen: nur das eigene Dokument, und zwingend mit
      // status "pending" und isAdmin false - so kann sich niemand selbst
      // sofort freischalten oder zum Admin machen, egal was das Frontend
      // schickt.
      allow create: if istEingeloggt()
                    && request.auth.uid == uid
                    && request.resource.data.status == 'pending'
                    && request.resource.data.isAdmin == false;

      // Ändern: Admins dürfen alles ändern (Freigeben/Ablehnen/Sperren/
      // Rolle/Admin-Status/Notiz/Umbenennen) - AUSSER bei einem als
      // "geschuetzt: true" markierten Account darf selbst ein Admin nicht
      // die Admin-Rechte entziehen oder den Freigabe-Status wegändern
      // (siehe verletztUnantastbarkeit() oben). Der Account selbst darf
      // NUR sein eigenes "lastLogin"-Feld aktualisieren (beim Einloggen) -
      // ODER, als dritte Ausnahme, sich selbst von "locked" zurück auf
      // "approved" setzen, aber NUR wenn die eigene befristete Sperre laut
      // Server-Uhrzeit bereits abgelaufen ist (siehe eigeneSperreAbgelaufen
      // oben). Das ist der "Selbstheilungs"-Mechanismus, der eine
      // zeitlich befristete Sperre automatisch enden lässt, ganz ohne
      // eigenen Server/Cloud Function.
      allow update: if (istAdmin() && !verletztUnantastbarkeit())
                    || (request.auth.uid == uid
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastLogin']))
                    || (request.auth.uid == uid
                        && resource.data.status == 'locked'
                        && resource.data.get('gesperrtBis', null) != null
                        && request.time > resource.data.gesperrtBis
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'lastLogin', 'gesperrtBis'])
                        && request.resource.data.status == 'approved');

      // Löschen: nur Admins, und niemals bei einem "geschuetzt"-Account.
      allow delete: if istAdmin() && !istUnantastbar();
    }

    /* ------------------------------------------------------------------
       usernames/{nameKleingeschrieben} — reserviert einen Benutzernamen,
       damit er nicht doppelt vergeben werden kann. Dokument enthält nur
       { uid }. Getrennt von "users", weil eine Verfügbarkeits-Prüfung per
       get() funktionieren muss, auch BEVOR man Admin oder überhaupt
       freigegeben ist (z. B. während der Registrierung selbst).
       ------------------------------------------------------------------ */
    match /usernames/{name} {
      // Jeder (auch nicht eingeloggt) darf prüfen, ob ein Name frei ist -
      // das Dokument enthält keine sensiblen Daten, nur eine UID.
      allow get: if true;

      // Niemand darf die komplette Namensliste auf einmal abfragen.
      allow list: if false;

      // Einen Namen reservieren: nur für die eigene UID (bei Registrierung)
      // oder durch einen Admin (z. B. beim direkten Anlegen eines Kontos
      // oder beim Umbenennen).
      allow create: if istEingeloggt() && (request.resource.data.uid == request.auth.uid || istAdmin());

      // Ein reserviertes Dokument wird nie "geändert", nur neu angelegt
      // oder gelöscht (siehe benenneUm in js/auth.js) - daher grundsätzlich
      // gesperrt.
      allow update: if false;

      // Freigeben (z. B. beim Umbenennen der alte Name, oder beim Löschen
      // eines Accounts): nur Admins.
      allow delete: if istAdmin();
    }

    /* ------------------------------------------------------------------
       adminLog/{logId} — Aktivitäts-Log für das Admin Panel. Ein Eintrag
       pro Admin-Aktion (Freigeben, Sperren, Rolle ändern, Löschen, ...),
       geschrieben von js/auth.js. Absichtlich unveränderlich: einmal
       geschrieben, kann ein Eintrag NIE mehr geändert oder gelöscht werden
       (auch nicht von einem Admin) - sonst wäre das Log selbst nicht mehr
       vertrauenswürdig.
       ------------------------------------------------------------------ */
    match /adminLog/{logId} {
      allow create: if istAdmin();
      allow list, get: if istAdmin();
      allow update, delete: if false;
    }

    /* ------------------------------------------------------------------
       Bestehende Collections der eigentlichen App - unverändert in ihrer
       DATENSTRUKTUR, aber jetzt zusätzlich an "istFreigegeben()" gekoppelt,
       statt (wie bisher) für jeden eingeloggten (auch anonymen) Nutzer
       offen zu sein. Bewusst JEDE Collection einzeln aufgeführt statt
       eines Wildcard-Musters ({document=**}) - ein Wildcard würde sich mit
       den spezifischeren Regeln oben (users/usernames) per OR verbinden
       und deren strengere Einschränkungen effektiv aufweichen.
       ------------------------------------------------------------------ */
    match /department/{dokument} {
      allow read, write: if istFreigegeben();
    }
    match /presence/{dokument} {
      allow read, write: if istFreigegeben();
    }
    match /notizen/{dokument} {
      allow read, write: if istFreigegeben();
    }
    match /verkaufslog/{dokument} {
      allow read, write: if istFreigegeben();
    }
    match /kontakte/{dokument} {
      allow read, write: if istFreigegeben();
    }
    match /ankuendigungen/{dokument} {
      allow read, write: if istFreigegeben();
    }

    /* ------------------------------------------------------------------
       handbuch/{dokument} — interne Dokumentenbibliothek (Einarbeitungs-
       leitfaden, Dienstvorschriften, Beförderungsrichtlinien, ...). Lesen
       ausschließlich für die in darfHandbuchSehen() genannten Ränge,
       Bearbeiten (Anlegen/Ändern/Löschen) ausschließlich für Admins - genau
       wie im Frontend (js/app.js), hier aber zusätzlich unabhängig vom
       Frontend erzwungen.
       ------------------------------------------------------------------ */
    match /handbuch/{dokument} {
      allow read: if istFreigegeben() && darfHandbuchSehen();
      allow write: if istFreigegeben() && istAdmin();
    }
  }
}
